      "title": "AI Decisions",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(titanops_ai_decisions_total)",
          "legendFormat": "Decisions",
          "refId": "A"
        }
      ]
    }
