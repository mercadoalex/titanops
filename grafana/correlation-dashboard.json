      "id": 4,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "eBeeControl Events",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(titanops_events_total{module=\"ebeecontrol\"}[$__interval])) by (event_type)",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Events from Quack module on shared timeline axis. No datasource configured: ensure a Prometheus datasource is available and selected. Shows 'inactive' when module is disabled.",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "events",
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "noValue": "inactive"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Quack Events",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(titanops_events_total{module=\"quack\"}[$__interval])) by (event_type)",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 6,
      "title": "Correlated Incidents",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Number of correlated incidents generated by the correlation engine. No datasource configured: ensure a Prometheus datasource is available and selected.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 22 },
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Active Correlated Incidents",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(titanops_correlated_incidents_active)",
          "legendFormat": "Incidents",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Average confidence score of correlated incidents. No datasource configured: ensure a Prometheus datasource is available and selected.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "unit": "percent",
          "noValue": "N/A"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 22 },
      "id": 8,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Avg Confidence Score",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg(titanops_correlation_confidence_score)",
          "legendFormat": "Confidence",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Count of auto-actions triggered by correlation engine. No datasource configured: ensure a Prometheus datasource is available and selected.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 22 },
      "id": 9,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Auto-Actions Triggered",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(titanops_auto_actions_total[30m]))",
          "legendFormat": "Actions",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Recent correlated incidents table. No datasource configured: ensure a Prometheus datasource is available and selected.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 10,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Time" }]
      },
      "title": "Recent Correlated Incidents",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "titanops_correlated_incidents_info",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["titanops", "correlation"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "30m", "value": "30m" },
        "hide": 0,
        "includeAll": false,
        "label": "Time Window",
        "multi": false,
        "name": "time_window",
        "options": [
          { "selected": false, "text": "15m", "value": "15m" },
          { "selected": true, "text": "30m", "value": "30m" },
          { "selected": false, "text": "1h", "value": "1h" },
          { "selected": false, "text": "3h", "value": "3h" },
          { "selected": false, "text": "6h", "value": "6h" },
          { "selected": false, "text": "12h", "value": "12h" },
          { "selected": false, "text": "24h", "value": "24h" }
        ],
        "query": "15m,30m,1h,3h,6h,12h,24h",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "TitanOps Correlation",
  "uid": "titanops-correlation",
  "version": 1,
  "weekStart": ""
